  },
  "files": [
    "bin"
  ],
  "engines": {
    "node": ">=18"
  },
  "optionalDependencies": {
    "@foir/demesne-cli-darwin-arm64": "0.0.0",
    "@foir/demesne-cli-darwin-x64": "0.0.0",
    "@foir/demesne-cli-linux-arm64": "0.0.0",
    "@foir/demesne-cli-linux-x64": "0.0.0",
    "@foir/demesne-cli-win32-x64": "0.0.0"
  }
