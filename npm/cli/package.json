{
  "name": "@foir/demesne-cli",
  "version": "0.0.0",
  "description": "Demesne CLI — compile one .demesne spec into Postgres RLS plus a typed app surface. Wraps the prebuilt Go binary for your platform.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/foir-io/demesne.git",
    "directory": "npm/cli"
  },
  "homepage": "https://github.com/foir-io/demesne#readme",
  "bugs": "https://github.com/foir-io/demesne/issues",
  "keywords": [
    "authorization",
    "rls",
    "postgres",
    "rebac",
    "cli"
  ],
  "bin": {
